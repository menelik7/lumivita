# Lumivita — environment variables
#
# Copy to .env.local for local dev and set the real values there (never commit
# .env.local). In production set these in the Vercel project settings.
# All values are SERVER-ONLY — do not prefix with NEXT_PUBLIC_.

# --- Brevo (early-access email capture) ---------------------------------------
# Until BOTH required vars below are set, POST /api/subscribe returns a clean
# 503 "not_configured" and no contact is created.

# Required. Brevo dashboard → SMTP & API → API Keys (create a server key).
BREVO_API_KEY=
# Required. Numeric id of the early-access contact list.
# Brevo dashboard → Contacts → Lists (the list's ID).
BREVO_LIST_ID=

# Optional — GDPR double opt-in (DOI). When BOTH are set, signups go through
# Brevo's DOI flow: a confirmation email is sent before the contact is added to
# the list. Leave both blank for a direct single-opt-in add.
# Numeric id of the DOI email template (Brevo → Campaigns → Templates).
BREVO_DOI_TEMPLATE_ID=
# URL users are redirected to after clicking the confirmation link.
BREVO_DOI_REDIRECT_URL=
