# Lumivita — environment variables
#
# Copy to .env.local for local dev and set the real values there (never commit
# .env.local). In production set these in the Vercel project settings.
# All values are SERVER-ONLY — do not prefix with NEXT_PUBLIC_.

# --- Brevo (early-access email capture) ---------------------------------------
# Double opt-in is handled by a Brevo AUTOMATION (the correct pattern for a form
# built outside Brevo): the backend adds the contact to the PENDING list, and the
# automation sends the confirmation email + moves them to CONFIRMED on click.
# The backend therefore only needs the API key + the PENDING list id.
#
# Until BOTH required vars are set, POST /api/subscribe returns 503
# "not_configured" and no contact is created.

# Required. Brevo dashboard → SMTP & API → API Keys (create a server key).
BREVO_API_KEY=

# Required. Numeric id of the EARLY_ACCESS_PENDING list (Contacts → Lists).
# The backend adds new signups here; the Brevo automation moves confirmed
# contacts to the CONFIRMED list (that id lives only in the automation — the
# backend never needs it).
BREVO_PENDING_LIST_ID=

# Optional. Override the Brevo API base URL (defaults to https://api.brevo.com/v3).
# BREVO_BASE_URL=
